@page
@model Licenta.Pages.Utilizatori.IndexModel

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<form asp-page="./Index" method="get">
    <div class="form-actions no-color">
        <p>
            Căutare:
            <input type="text" name="SearchString" value="@Model.CurrentFilter" />
            <input type="submit" value="Search" class="btn btn-primary" /> |
            <a asp-page="./Index">Înapoi</a>
        </p>
    </div>
</form>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Utilizator[0].Nume)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Utilizator[0].Prenume)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Utilizator[0].CNP)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Utilizator[0].Email)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Utilizator[0].NrTelefon)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Utilizator) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Nume)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Prenume)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.CNP)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Email)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.NrTelefon)
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.ID">Edit</a> |
                <a asp-page="./Details" asp-route-id="@item.ID">Details</a> |
                <a asp-page="./Delete" asp-route-id="@item.ID">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
