@page
@model Licenta.Pages.Combustibili.EditModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Editare</h1>

<h4>Combustibil</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Combustibil.ID" />
            <div class="form-group">
                <label asp-for="Combustibil.TipCombustibil" class="control-label"></label>
                <input asp-for="Combustibil.TipCombustibil" class="form-control" />
                <span asp-validation-for="Combustibil.TipCombustibil" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Salvare" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index" class="btn btn-primary">Înapoi</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
